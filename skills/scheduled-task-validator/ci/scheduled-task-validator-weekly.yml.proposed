# To activate this workflow:
#   git mv skills/scheduled-task-validator/ci/scheduled-task-validator-weekly.yml.proposed \
#          .github/workflows/scheduled-task-validator-weekly.yml
#   git commit -m 'activate weekly validator'
#   git push
#
# Prereq: create a repo secret SAIL_TASKS_TOKEN with read access to
# samaguiar1982-cpu/sail-scheduled-tasks (a fine-grained PAT scoped to that
# single repo, contents:read).
#
# Implements Q-W1=A (Sam pick, 2026-04-23): migrate the validator off the
# laptop launchd plist (TCC/Full Disk Access wall) onto a remote runner.
# Mondays 15:00 UTC mirrors the local plist's wall-clock time during EDT.
#
# v2.2.0 (Q-W8=A, 2026-04-24): validate.sh now honors SAIL_SCHED_DIR and
# SAIL_REPORT_DIR env vars, so we no longer need the symlink/sudo/chown dance.
# Defaults preserve macOS launchd behavior; CI just sets the two env vars to
# point at the checked-out repos and the workflow workspace.

name: scheduled-task-validator weekly

on:
  schedule:
    - cron: '0 15 * * 1'
  workflow_dispatch: {}

permissions:
  contents: read

jobs:
  validate:
    name: Run validate.sh against mirrored SF-chain tasks
    runs-on: ubuntu-latest
    timeout-minutes: 10
    env:
      SAIL_SCHED_DIR: ${{ github.workspace }}/sail-scheduled-tasks
      SAIL_REPORT_DIR: ${{ github.workspace }}/validator-runs
    steps:
      - name: Checkout codex-skills
        uses: actions/checkout@v4
        with:
          path: codex-skills

      - name: Checkout sail-scheduled-tasks
        uses: actions/checkout@v4
        with:
          repository: samaguiar1982-cpu/sail-scheduled-tasks
          token: ${{ secrets.SAIL_TASKS_TOKEN }}
          path: sail-scheduled-tasks

      - name: Prepare report dir
        run: mkdir -p "$SAIL_REPORT_DIR"

      - name: Show staged layout (sanity check)
        run: |
          echo "--- Scheduled tasks visible to validator ---"
          ls -la "$SAIL_SCHED_DIR" || true
          echo "--- Validator script ---"
          ls -la "$GITHUB_WORKSPACE/codex-skills/skills/scheduled-task-validator/" || true

      - name: Run validate.sh
        id: validator
        run: |
          set +e
          bash "$GITHUB_WORKSPACE/codex-skills/skills/scheduled-task-validator/validate.sh"
          EC=$?
          set -e
          echo "exit_code=$EC" >> "$GITHUB_OUTPUT"
          if [ "$EC" -eq 2 ]; then
            echo "::error::validate.sh self-integrity check failed. Pinned hash mismatch."
            exit 2
          fi
          {
            echo "## scheduled-task-validator weekly run"
            echo
            echo "- Exit code: \`$EC\`"
            if [ "$EC" -eq 0 ]; then
              echo "- Result: **PASS**"
            else
              echo "- Result: **FAIL** (see report artifact for per-check detail)"
            fi
          } >> "$GITHUB_STEP_SUMMARY"

      - name: Append report to job summary
        if: always()
        run: |
          REPORT="$SAIL_REPORT_DIR/$(date -u +%Y-%m-%d).md"
          if [ -f "$REPORT" ]; then
            echo "" >> "$GITHUB_STEP_SUMMARY"
            echo "---" >> "$GITHUB_STEP_SUMMARY"
            echo "" >> "$GITHUB_STEP_SUMMARY"
            cat "$REPORT" >> "$GITHUB_STEP_SUMMARY"
          else
            echo "::warning::No report found at $REPORT"
          fi

      - name: Upload report as artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: validator-run-${{ github.run_id }}
          path: ${{ github.workspace }}/validator-runs/*.md
          if-no-files-found: warn
          retention-days: 90

      - name: Fail job if validator reported FAIL
        if: steps.validator.outputs.exit_code != '0'
        run: |
          echo "::error::Validator exit code was ${{ steps.validator.outputs.exit_code }}. See report artifact and step summary."
          exit 1
